<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="438.0" prefWidth="250.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sistemagerenciamentotabulando.controller.HorariosController">
   <children>
      <Label layoutX="57.0" layoutY="24.0" text="Adicionar Horário">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="76.0" text="Data">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="139.0" text="Turno">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="200.0" text="Hora">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="260.0" text="Nome do Monitor">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="nomeMonitorAdicionar" layoutX="29.0" layoutY="278.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o nome do monitor" />
      <Button fx:id="btnFecharAdicionar" layoutX="29.0" layoutY="369.0" mnemonicParsing="false" onAction="#fecharTelaAdicionar" prefHeight="34.0" prefWidth="78.0" style="-fx-background-color: #666666;" text="Cancelar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="142.0" layoutY="369.0" mnemonicParsing="false" onAction="#onAdcHorarioClicked" prefHeight="34.0" prefWidth="78.0" style="-fx-background-color: #f58220;" text="Salvar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="12.0" layoutY="23.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="34.0" text="&lt;-" />
      <TextField fx:id="horaAdicionar" layoutX="29.0" layoutY="218.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o horário" />
      <TextField fx:id="turnoAdicionar" layoutX="29.0" layoutY="157.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o turno" />
      <DatePicker fx:id="dataHorarioAdicionar" layoutX="29.0" layoutY="98.0" prefHeight="26.0" prefWidth="192.0" />
      <Label layoutX="29.0" layoutY="312.0" text="Status do horário">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="statusHorarioAdicionar" layoutX="29.0" layoutY="330.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o status do horário" />
