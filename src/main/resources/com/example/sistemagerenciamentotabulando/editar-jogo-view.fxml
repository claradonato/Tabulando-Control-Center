<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="446.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sistemagerenciamentotabulando.controller.EditarJogoController">
   <children>
      <Label layoutX="68.0" layoutY="23.0" text="Editar Jogo">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="76.0" text="Título">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="139.0" text="Tipo">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="200.0" text="Mínimo de jogadores">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="260.0" text="Máximo de jogadores">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="maxJogadores" layoutX="29.0" layoutY="278.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o número máximo de jog" />
      <Button fx:id="btnFechar" layoutX="29.0" layoutY="328.0" mnemonicParsing="false" onAction="#fecharTela" prefHeight="34.0" prefWidth="78.0" style="-fx-background-color: #666666;" text="Cancelar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="353.0" layoutY="328.0" mnemonicParsing="false" onAction="#onSalvarClicked" prefHeight="34.0" prefWidth="78.0" style="-fx-background-color: #f58220;" text="Salvar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="12.0" layoutY="23.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="34.0" text="&lt;-" />
      <TextField fx:id="minJogadores" layoutX="29.0" layoutY="218.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o número mínimo de jog" />
      <TextField fx:id="tipo" layoutX="29.0" layoutY="157.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o tipo" />
      <TextField fx:id="titulo" layoutX="29.0" layoutY="94.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o título do jogo" />
      <Label layoutX="238.0" layoutY="76.0" text="Descrição">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="descricao" layoutX="238.0" layoutY="94.0" prefHeight="18.0" prefWidth="192.0" promptText="Digite a descrição do jogo" />
      <Label layoutX="238.0" layoutY="139.0" text="Marca">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="marca" layoutX="238.0" layoutY="157.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite a marca" />
      <Label layoutX="238.0" layoutY="200.0" text="Faixa Etária">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="faixaEtaria" layoutX="238.0" layoutY="218.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite a faixa etária" />
      <Label layoutX="241.0" layoutY="260.0" text="Tempo de partida">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="tempoPartida" layoutX="238.0" layoutY="278.0" prefHeight="26.0" prefWidth="192.0" promptText="Digite o tempo de partida" />
   </children>
</AnchorPane>
